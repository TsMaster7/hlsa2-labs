    {
      "id": 2,
      "type": "timeseries",
      "title": "Request Rate (req/s by route)",
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "from(bucket: \"metrics\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"prometheus\" and r._field == \"http_requests_total\") |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: false) |> derivative(unit: 1s, nonNegative: true) |> group(columns: [\"route\"]) |> aggregateWindow(every: v.windowPeriod, fn: sum, createEmpty: false)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error Rate %",
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 4,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "from(bucket: \"metrics\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"prometheus\" and r._field == \"http_requests_total\") |> increase() |> last() |> group() |> reduce(identity: {total: 0.0, err: 0.0}, fn: (r, accumulator) => ({total: accumulator.total + r._value, err: accumulator.err + (if r.status_class == \"5xx\" then r._value else 0.0)})) |> map(fn: (r) => ({_value: if r.total > 0.0 then r.err / r.total * 100.0 else 0.0}))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99",
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      },
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "from(bucket: \"metrics\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"prometheus\" and r._field == \"http_request_duration_ms_bucket\") |> group(columns: [\"le\", \"route\", \"method\"]) |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: false) |> derivative(unit: v.windowPeriod, nonNegative: true) |> group(columns: [\"le\", \"_time\"]) |> sum() |> group(columns: [\"_time\"]) |> map(fn: (r) => ({r with le: float(v: r.le)})) |> sort(columns: [\"le\"]) |> histogramQuantile(quantile: 0.5, upperBoundColumn: \"le\", countColumn: \"_value\", onNonmonotonic: \"force\") |> set(key: \"_field\", value: \"p50\") |> group(columns: [\"_field\"]) |> sort(columns: [\"_time\"]) |> keep(columns: [\"_time\", \"_value\", \"_field\"])"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "from(bucket: \"metrics\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"prometheus\" and r._field == \"http_request_duration_ms_bucket\") |> group(columns: [\"le\", \"route\", \"method\"]) |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: false) |> derivative(unit: v.windowPeriod, nonNegative: true) |> group(columns: [\"le\", \"_time\"]) |> sum() |> group(columns: [\"_time\"]) |> map(fn: (r) => ({r with le: float(v: r.le)})) |> sort(columns: [\"le\"]) |> histogramQuantile(quantile: 0.95, upperBoundColumn: \"le\", countColumn: \"_value\", onNonmonotonic: \"force\") |> set(key: \"_field\", value: \"p95\") |> group(columns: [\"_field\"]) |> sort(columns: [\"_time\"]) |> keep(columns: [\"_time\", \"_value\", \"_field\"])"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "from(bucket: \"metrics\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"prometheus\" and r._field == \"http_request_duration_ms_bucket\") |> group(columns: [\"le\", \"route\", \"method\"]) |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: false) |> derivative(unit: v.windowPeriod, nonNegative: true) |> group(columns: [\"le\", \"_time\"]) |> sum() |> group(columns: [\"_time\"]) |> map(fn: (r) => ({r with le: float(v: r.le)})) |> sort(columns: [\"le\"]) |> histogramQuantile(quantile: 0.99, upperBoundColumn: \"le\", countColumn: \"_value\", onNonmonotonic: \"force\") |> set(key: \"_field\", value: \"p99\") |> group(columns: [\"_field\"]) |> sort(columns: [\"_time\"]) |> keep(columns: [\"_time\", \"_value\", \"_field\"])"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false,
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 200
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
