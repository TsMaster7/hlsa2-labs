# Copy to .env and edit if any of the default ports conflict with
# something else on your dev machine (a host postgres, a personal
# grafana, an unrelated app on :8080, etc.).
#
# When you change one of these, also adjust the SUT_URL you pass to
# the k6 scripts (e.g. SUT_URL=http://localhost:18080 make perf-baseline).

LAB_SUT_PORT=8080
LAB_DOWNSTREAM_PORT=8081
LAB_PROMETHEUS_PORT=9090
LAB_GRAFANA_PORT=3000

# The candidate optimization knob for the three-run regression.
# Default of 10 matches a typical un-tuned production deploy.
SUT_DB_POOL_SIZE=10

# Optional: tighten or loosen the downstream client behaviour.
# SUT_DOWNSTREAM_POOL_SIZE=256
# SUT_DOWNSTREAM_TIMEOUT_MS=30000
