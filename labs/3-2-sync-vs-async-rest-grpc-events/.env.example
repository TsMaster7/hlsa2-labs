# Copy to .env and edit if any of the default ports conflict with
# something else on your dev machine.
#
# When you change a host-side port, also pass the new URL to the k6
# scripts (e.g. REST_URL=http://localhost:18080 make bench-protocols).

LAB_REST_PORT=8080
LAB_GRPC_PORT=9000
LAB_GATEWAY_PORT=8090
LAB_AUTH_PORT=8091
LAB_PRICING_PORT=8092
LAB_INVENTORY_PORT=8093
LAB_PRODUCER_PORT=8094
LAB_CONSUMER_PORT=8095
LAB_REDPANDA_PORT=9092
LAB_PROMETHEUS_PORT=9090
LAB_GRAFANA_PORT=3000
LAB_POSTGRES_EXPORTER_PORT=9187

# Default protocol-bench knobs (override per run via env or on the make line).
TARGET_RPS=200
PAYLOAD=small

# Gateway candidate knobs - flip via env when running step 7's regression.
# off|on
CIRCUIT_BREAKER=off
# rest|grpc - which transport the gateway uses internally for /lookup
GATEWAY_LOOKUP_TRANSPORT=rest
# sync|event - whether the audit side-effect runs inline or is emitted
GATEWAY_AUDIT_MODE=sync

# Async path knobs.
# off|on
FLOW_CONTROL=off
# naive|idempotent
CONSUMER_MODE=idempotent
# Bounded queue size when FLOW_CONTROL=on
CONSUMER_QUEUE_MAX=10000
# Hard guard so the no-bp run can never OOM the box
ASYNC_MAX_QUEUE_GUARD=2000000
# Throttle replay so it doesn't melt postgres - msgs/sec, 0 = unthrottled
REPLAY_RATE_LIMIT=0
