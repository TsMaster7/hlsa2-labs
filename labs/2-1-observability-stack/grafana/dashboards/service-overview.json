    {
      "id": 5,
      "type": "heatmap",
      "title": "Latency distribution (heatmap, ms buckets)",
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      },
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 24,
        "h": 9
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "from(bucket: \"metrics\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"prometheus\" and r._field == \"http_request_duration_ms_bucket\") |> group(columns: [\"le\", \"route\", \"method\"]) |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: false) |> derivative(unit: v.windowPeriod, nonNegative: true) |> group(columns: [\"le\", \"_time\"]) |> sum() |> group() |> pivot(rowKey: [\"_time\"], columnKey: [\"le\"], valueColumn: \"_value\") |> map(fn: (r) => ({_time: r._time, \"5\": (if exists r[\"5\"] then r[\"5\"] else 0.0), \"10\": (if exists r[\"10\"] then r[\"10\"] else 0.0) - (if exists r[\"5\"] then r[\"5\"] else 0.0), \"25\": (if exists r[\"25\"] then r[\"25\"] else 0.0) - (if exists r[\"10\"] then r[\"10\"] else 0.0), \"50\": (if exists r[\"50\"] then r[\"50\"] else 0.0) - (if exists r[\"25\"] then r[\"25\"] else 0.0), \"75\": (if exists r[\"75\"] then r[\"75\"] else 0.0) - (if exists r[\"50\"] then r[\"50\"] else 0.0), \"100\": (if exists r[\"100\"] then r[\"100\"] else 0.0) - (if exists r[\"75\"] then r[\"75\"] else 0.0), \"150\": (if exists r[\"150\"] then r[\"150\"] else 0.0) - (if exists r[\"100\"] then r[\"100\"] else 0.0), \"200\": (if exists r[\"200\"] then r[\"200\"] else 0.0) - (if exists r[\"150\"] then r[\"150\"] else 0.0), \"300\": (if exists r[\"300\"] then r[\"300\"] else 0.0) - (if exists r[\"200\"] then r[\"200\"] else 0.0), \"500\": (if exists r[\"500\"] then r[\"500\"] else 0.0) - (if exists r[\"300\"] then r[\"300\"] else 0.0), \"1000\": (if exists r[\"1000\"] then r[\"1000\"] else 0.0) - (if exists r[\"500\"] then r[\"500\"] else 0.0)}))"
        }
      ],
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": {
          "mode": "scheme",
          "scheme": "Spectral",
          "steps": 64,
          "reverse": false,
          "exponent": 0.5,
          "fill": "dark-orange"
        },
        "yAxis": {
          "axisPlacement": "left",
          "unit": "ms",
          "reverse": false
        },
        "rowsFrame": {
          "layout": "auto"
        },
        "tooltip": {
          "show": true,
          "yHistogram": false
        },
        "legend": {
          "show": true
        },
        "cellValues": {},
        "filterValues": {
          "le": 1e-09
        },
        "exemplars": {
          "color": "rgba(255,0,255,0.7)"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "scaleDistribution": {
              "type": "linear"
            },
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          }
        },
        "overrides": []
      }
    },
