# syntax=docker/dockerfile:1.7
# Multi-stage build for lookup-svc. Build inside the container so the
# host doesn't need a Go toolchain. go.sum is regenerated by `go mod
# tidy` on first build because we don't commit it (see README).

FROM golang:1.22-alpine AS build
WORKDIR /src

RUN apk add --no-cache git
COPY go.mod ./
RUN go mod download || true

COPY . .
RUN go mod tidy
RUN CGO_ENABLED=0 GOOS=linux GOFLAGS=-mod=mod go build -trimpath -ldflags="-s -w" -o /out/lookup-svc ./cmd/lookup-svc

FROM alpine:3.20
RUN apk add --no-cache wget ca-certificates && update-ca-certificates
COPY --from=build /out/lookup-svc /usr/local/bin/lookup-svc
EXPOSE 8080 9000
ENTRYPOINT ["/usr/local/bin/lookup-svc"]
